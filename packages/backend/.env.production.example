# 本番用の変数一覧（実値はコミットしない。ホスティングの環境変数で設定する）
# コピーしてローカル検証する場合のみ: cp .env.production.example .env.production

NODE_ENV=production
PORT=3000

# 必須。マネージド DB などの接続文字列を入れる
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/jinro

# 必須相当（access token 署名）
JWT_SECRET=

# CORS_ORIGIN=https://example.com
# AVATAR_IMAGE_PUBLIC_BASE_URL=https://cdn.example.com
