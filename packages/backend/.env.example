# 共通の雛形。環境ごとに `.env.development` / `.env.production` を使う。
# 使い方:
#   cp .env.development.example .env.development
#   cp .env.production.example .env.production   # 本番値はデプロイ環境で設定推奨

PORT=3000

# 開発: 未設定なら docker-compose の Postgres（jinro:jinro@localhost:5432/jinro）にフォールバック
# 本番: 必須（未設定だと起動時にエラー）
# DATABASE_URL=postgresql://jinro:jinro@localhost:5432/jinro
